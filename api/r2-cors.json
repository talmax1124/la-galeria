{
  "rules": [
    {
      "allowedOrigins": ["*"],
      "allowedMethods": ["GET", "PUT", "HEAD", "DELETE"],
      "allowedHeaders": ["Content-Type", "Authorization", "x-amz-date", "x-amz-content-sha256", "x-amz-security-token"],
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
